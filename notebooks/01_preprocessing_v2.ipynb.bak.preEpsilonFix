   "source": [
    "# Two-panel HVG plot. seurat_v3 stores variances/variances_norm so default\n",
    "# sc.pl.highly_variable_genes leaves half the figure empty. Hand-rolled to:\n",
    "#   - put NOT-normalized (means vs variances) on LEFT, NORMALIZED on RIGHT\n",
    "#   - log-log on both panels so a few extreme genes (eg islet markers like\n",
    "#     GHRL/CHGA/IAPP at variances_norm > 16) don't squash the bulk distribution\n",
    "#   - annotate the top-N highly-variable genes by name so the outliers are\n",
    "#     identifiable without leaving the figure\n",
    "#   - red HV vs light-grey other, larger dots for legibility\n",
    "import matplotlib.pyplot as _plt\n",
    "import numpy as _np\n",
    "\n",
    "_var = adata.var\n",
    "_is_hv = _var[\"highly_variable\"].astype(bool).to_numpy()\n",
    "_means = _var[\"means\"].to_numpy()\n",
    "_var_raw = _var[\"variances\"].to_numpy()\n",
    "_var_norm = _var[\"variances_norm\"].to_numpy() if \"variances_norm\" in _var.columns else None\n",
    "_names = _var.index.to_numpy()\n",
    "\n",
    "n_hv = int(_is_hv.sum())\n",
    "n_other = int((~_is_hv).sum())\n",
    "N_LABEL = 5  # how many top genes to annotate per panel\n",
    "\n",
    "def _label_top(ax, x, y, names, k):\n",
    "    if not len(x):\n",
    "        return\n",
    "    order = _np.argsort(-y)[:k]\n",
    "    for idx in order:\n",
    "        ax.annotate(\n",
    "            str(names[idx]),\n",
    "            xy=(x[idx], y[idx]),\n",
    "            xytext=(6, -2), textcoords=\"offset points\",\n",
    "            fontsize=8, color=\"#444\",\n",
    "            arrowprops=dict(arrowstyle=\"-\", color=\"#888\", lw=0.5),\n",
    "        )\n",
    "\n",
    "def _panel(ax, x, y, hv_mask, ylabel, ytitle, ylog=True):\n",
    "    ax.scatter(x[~hv_mask], y[~hv_mask], s=8, c=\"#cfcfcf\", alpha=0.55,\n",
    "               linewidths=0, label=f\"Other ({(~hv_mask).sum():,})\")\n",
    "    ax.scatter(x[hv_mask], y[hv_mask], s=14, c=\"#d62728\", alpha=0.85,\n",
    "               linewidths=0, label=f\"Highly variable ({hv_mask.sum():,})\")\n",
    "    ax.set_xscale(\"log\")\n",
    "    if ylog:\n",
    "        ax.set_yscale(\"log\")\n",
    "    ax.set_xlabel(\"mean counts\"); ax.set_ylabel(ylabel)\n",
    "    ax.set_title(ytitle)\n",
    "    ax.legend(loc=\"best\", framealpha=0.9)\n",
    "    ax.grid(True, alpha=0.3, linestyle=\"--\")\n",
    "    # Label top HV genes\n",
    "    _label_top(ax, x[hv_mask], y[hv_mask], _names[hv_mask], N_LABEL)\n",
    "\n",
    "if _var_norm is None:\n",
    "    _plt.figure(figsize=(7, 6))\n",
    "    _panel(_plt.gca(), _means, _var_raw, _is_hv, \"variance\",\n",
    "           \"Highly variable genes (not normalized)\")\n",
    "    _plt.tight_layout()\n",
    "else:\n",
    "    fig, axes = _plt.subplots(1, 2, figsize=(14, 6))\n",
    "    _panel(axes[0], _means, _var_raw, _is_hv, \"variance\", \"Not normalized\", ylog=True)\n",
    "    _panel(axes[1], _means, _var_norm, _is_hv, \"normalized variance\", \"Normalized\", ylog=True)\n",
    "    _plt.tight_layout()\n",
    "\n",
    "_plt.savefig(FIGURES_DIR / \"highly_variable_genes.png\", dpi=200, bbox_inches=\"tight\")\n",
    "_plt.show()\n"
   ]
