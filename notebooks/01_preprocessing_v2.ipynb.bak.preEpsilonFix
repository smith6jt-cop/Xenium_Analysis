    "ax1.legend(_lines + _lines2, _labels + _labels2, loc=\"upper right\", framealpha=0.9)\n",
    "\n",
    "plt.title(f\"PCA variance ratio ({_n} components) \u2014 elbow at PC {_elbow}\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"pca_variance_ratio.png\", dpi=200, bbox_inches=\"tight\")\n",
    "plt.show()\n"
