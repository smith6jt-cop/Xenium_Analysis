   "source": [
    "# Pipeline aligned with 10x Xenium 5k tutorial, GPU-accelerated where it helps:\n",
    "# 1) preserve raw counts, 2) seurat_v3 HVG (metadata only, CPU), 3) normalize_total\n",
    "# (CPU), 4) log1p (CPU), 5) move .X to GPU, 6) rsc.pp.scale (GPU,\n",
    "# zero_center=False), 7) rsc.pp.pca (GPU randomized SVD), 8) move back to CPU,\n",
    "# 9) rsc.pp.neighbors (cuML kNN, GPU, auto-uploads X_pca), 10) scanpy CPU UMAP\n",
    "# (rapids UMAP outliers \u2014 CLAUDE.md), 11) scanpy CPU igraph leiden (cugraph\n",
    "# leiden has dask-cuda version drift). Progress prints (flush=True).\n",
    "import time, sys\n",
    "\n",
    "def _step(label):\n",
    "    _step.t0 = getattr(_step, \"t0\", None) or time.time()\n",
    "    now = time.time()\n",
    "    if _step.prev is not None:\n",
    "        dt = now - _step.prev\n",
    "        print(f\"  [01] {label} (prev step: {dt:5.1f}s)\", flush=True)\n",
    "    else:\n",
    "        print(f\"  [01] {label}\", flush=True)\n",
    "    _step.prev = now\n",
    "_step.prev = None\n",
    "\n",
    "_step(\"counts layer\")\n",
    "adata.layers[\"counts\"] = adata.X.copy()\n",
    "\n",
    "_step(\"HVG seurat_v3 (metadata only)\")\n",
    "sc.pp.highly_variable_genes(\n",
    "    adata, layer=\"counts\", n_top_genes=2000, flavor=\"seurat_v3\", subset=False,\n",
    ")\n",
    "\n",
    "_step(\"normalize_total\")\n",
    "sc.pp.normalize_total(adata)\n",
    "_step(\"log1p\")\n",
    "sc.pp.log1p(adata)\n",
    "adata.layers[\"lognorm\"] = adata.X.copy()\n",
    "\n",
    "_step(\"move .X to GPU (anndata_to_GPU; layers stay on CPU)\")\n",
    "rsc.get.anndata_to_GPU(adata)\n",
    "\n",
    "_step(\"rsc.pp.scale (GPU, zero_center=False)\")\n",
    "rsc.pp.scale(adata, zero_center=False, max_value=10)\n",
    "\n",
    "_step(f\"rsc.pp.pca n_comps=50 (GPU, {adata.n_obs:,} x {adata.n_vars:,})\")\n",
    "rsc.pp.pca(adata, n_comps=50, random_state=0)\n",
    "\n",
    "_step(\"move .X + obsm back to CPU (anndata_to_CPU convert_all=True)\")\n",
    "rsc.get.anndata_to_CPU(adata, convert_all=True)\n",
    "\n",
    "_step(\"restore .X = layers['lognorm']\")\n",
    "adata.X = adata.layers[\"lognorm\"].copy()\n",
    "\n",
    "_step(f\"rsc.pp.neighbors k=15 cosine (GPU, auto-uploads X_pca)\")\n",
    "rsc.pp.neighbors(adata, n_neighbors=15, metric=\"cosine\", random_state=0, use_rep=\"X_pca\")\n",
    "\n",
    "_step(\"UMAP min_dist=0.5\")\n",
    "sc.tl.umap(adata, min_dist=0.5, spread=1.0, random_state=0)\n",
    "\n",
    "_step(f\"leiden igraph n_iterations=-1 resolution={LEIDEN_RES}\")\n",
    "sc.tl.leiden(\n",
    "    adata, resolution=LEIDEN_RES, key_added=\"leiden_1.5\",\n",
    "    flavor=\"igraph\", n_iterations=-1, directed=False, random_state=0,\n",
    ")\n",
    "_step(\"cell 18 done\")\n"
