    "# PCA variance ratio: bar/line of per-PC variance + cumulative line on a twin\n",
    "# axis + a marker at the \"elbow\" (largest 2nd derivative on the log scale).\n",
    "# 50 components computed in cell 18 so the curve actually shows where it levels.\n",
    "import numpy as _np\n",
    "\n",
    "_vr = adata.uns[\"pca\"][\"variance_ratio\"]\n",
    "_n = len(_vr)\n",
    "_cum = _np.cumsum(_vr)\n",
    "\n",
    "# Elbow / knee detection: log-scale 2nd difference\n",
    "_log_vr = _np.log(_np.maximum(_vr, 1e-12))\n",
    "if _n >= 4:\n",
    "    _d2 = _np.diff(_log_vr, n=2)\n",
    "    # +2 because diff twice shifts by 2; +1 to convert 0-based to 1-based PC index\n",
    "    _elbow = int(_np.argmax(_d2)) + 2 + 1\n",
    "    _elbow = max(1, min(_elbow, _n))\n",
    "else:\n",
    "    _elbow = _n\n",
    "\n",
    "fig, ax1 = plt.subplots(figsize=(10, 6))\n",
    "_x = _np.arange(1, _n + 1)\n",
    "ax1.plot(_x, _vr, \"o-\", color=\"#1f77b4\", lw=1.5, markersize=4,\n",
    "         label=\"variance ratio (per PC)\")\n",
    "ax1.set_xlabel(\"Principal component\")\n",
    "ax1.set_ylabel(\"variance ratio (log)\", color=\"#1f77b4\")\n",
    "ax1.set_yscale(\"log\")\n",
    "ax1.tick_params(axis=\"y\", labelcolor=\"#1f77b4\")\n",
    "ax1.grid(True, alpha=0.3, linestyle=\"--\")\n",
    "\n",
    "ax2 = ax1.twinx()\n",
    "ax2.plot(_x, _cum, \"-\", color=\"#d62728\", lw=2, label=\"cumulative variance\")\n",
    "ax2.set_ylabel(\"cumulative variance (linear)\", color=\"#d62728\")\n",
    "ax2.tick_params(axis=\"y\", labelcolor=\"#d62728\")\n",
    "ax2.set_ylim(0, 1.0)\n",
    "\n",
    "# Annotate elbow\n",
    "ax1.axvline(_elbow, color=\"#444\", linestyle=\":\", lw=1.2, alpha=0.8)\n",
    "ax1.annotate(f\"elbow ~ PC {_elbow}\\ncumulative {_cum[_elbow-1]*100:.1f}%\",\n",
    "             xy=(_elbow, _vr[_elbow-1]), xytext=(_elbow + 1, _vr[_elbow-1]*3),\n",
    "             fontsize=9, color=\"#444\",\n",
    "             arrowprops=dict(arrowstyle=\"->\", color=\"#888\", lw=0.8))\n",
    "\n",
    "# Annotate cumulative milestones (80, 90, 95%)\n",
