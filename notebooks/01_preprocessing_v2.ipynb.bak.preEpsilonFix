    "    if _idx <= _n:\n",
    "        ax2.axhline(_frac, color=_color, linestyle=\":\", lw=0.8, alpha=0.5)\n",
    "        ax2.text(_n - 0.5, _frac + 0.005, f\"{int(_frac*100)}% @ PC {_idx}\",\n",
    "                 fontsize=8, color=_color, ha=\"right\")\n",
    "\n",
    "# Combined legend\n",
