    "        mad = np.median(np.abs(c - med)) + 1e-12\n",
    "        thr = med - mad\n",
    "        is_indet = mask & (conf < thr)\n",
    "        bucket = \"Indeterminate_endocrine\" if ct in {\"Alpha\", \"Delta\", \"Epsilon\"} else \"Indeterminate_exocrine\"\n",
